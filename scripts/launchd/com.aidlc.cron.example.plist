<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.aidlc.cron</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>-lc</string>
    <string>source $HOME/.config/aidlc/github.env 2&gt;/dev/null; exec $HOME/.ai-dlc/scripts/aidlc-cron.sh</string>
  </array>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
  </dict>
  <key>StartInterval</key>
  <integer>900</integer>
  <key>StandardOutPath</key>
  <string>/tmp/aidlc-cron.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/aidlc-cron.err</string>
  <key>RunAtLoad</key>
  <false/>
</dict>
</plist>
